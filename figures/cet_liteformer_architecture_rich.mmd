  "theme": "base",
  "themeVariables": {
    "fontFamily": "Segoe UI, Helvetica Neue, Arial, sans-serif",
    "fontSize": "15px",
    "primaryColor": "#E8EEF7",
    "primaryTextColor": "#1A237E",
    "primaryBorderColor": "#3949AB",
    "secondaryColor": "#E0F2F1",
